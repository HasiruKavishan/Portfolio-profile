---
import WorkCard from './WorkCard.astro';
import StatBox from './StatBox.astro';
import Skills from './Skills.astro';
import Experience from './Experience.astro';

const works = [
  {
    num: '001',
    title: 'Coonnect HR Platform',
    category: 'Featured',
    accent: true,
    description:
      'End-to-end HR & workforce management platform with B2C, B2B, and Admin modules. Built with React.js, Spring Boot & MongoDB.',
    link: 'https://www.linkedin.com/in/hasiru-kavishan-2715a7a2/',
  },
  {
    num: '002',
    title: 'Monidas IoT Platform',
    category: 'IoT · Cloud',
    accent: false,
    description:
      'Unified IoT platform aggregating data from multiple device sources via ChirpStack (LoRaWAN). Cloud-deployed and scalable.',
    link: 'https://www.linkedin.com/in/hasiru-kavishan-2715a7a2/',
  },
  {
    num: '003',
    title: 'Supply Chain Automation',
    category: 'Enterprise',
    accent: false,
    description:
      'Fleet & transport management system solving real supply chain problems for exporters, importers & freight forwarders.',
    link: 'https://www.linkedin.com/in/hasiru-kavishan-2715a7a2/',
  },
];

const stats = [
  { label: 'Experience', value: '5+ Years' },
  {
    label: 'Stack',
    value: 'React · Spring Boot\nNestJs · MongoDB',
    small: true,
  },
];
---

<div class="font-mono bg-[#fdf6ee] text-[#111] min-h-screen flex flex-col">
  <!-- Header -->
  <header class="border-b-[3px] border-[#111] flex flex-col lg:flex-row">
    <!-- Logo -->
    <div
      class="order-1 px-5 md:px-7 py-5 lg:border-r-[3px] border-[#111] border-b lg:border-b-0"
    >
      <div
        class="font-barlow text-[28px] font-black tracking-tight leading-none"
      >
        HK<span class="text-[#ff3d00]">.</span>
      </div>
      <div class="text-[10px] text-[#888] mt-1 tracking-widest">
        FULLSTACK ENGINEER
      </div>
    </div>

    <div
      class="order-2 lg:order-3 px-5 md:px-7 py-4 lg:py-0 flex items-center gap-2 text-[11px] border-b lg:border-b-0 lg:border-l border-[#ddd]"
    >
      <span class="w-2 h-2 rounded-full bg-[#00c851] animate-pulse"></span>
      Open to opportunities
    </div>

    <!-- Navigation -->
    <nav class="order-3 lg:order-2 flex flex-wrap lg:flex-nowrap lg:flex-1">
      {
        ['WORK', 'SKILLS', 'EXPERIENCE', 'CONTACT'].map((link, index, arr) => (
          <a
            href={`#${link.toLowerCase()}`}
            class={`px-5 md:px-6 py-4 md:py-5 text-[11px] tracking-[0.1em]
      border-r border-[#ddd]
      hover:bg-[#111] hover:text-[#f2f0eb]
      transition-colors duration-150
      flex items-center justify-center
      whitespace-nowrap
      ${index === arr.length - 1 ? 'border-r-0 lg:border-r' : ''}`}
          >
            {link}
          </a>
        ))
      }
    </nav>
  </header>

  <!-- Hero -->
  <section class="grid grid-cols-1 lg:grid-cols-2 border-b-[3px] border-[#111]">
    <!-- Left -->
    <div
      class="p-6 md:p-8 lg:p-10 lg:border-r-[3px] border-[#111] flex flex-col gap-6 md:gap-8"
    >
      <p class="text-[11px] tracking-[0.15em] text-[#888]">
        // Fullstack Software Engineer — Sri Lanka
      </p>

      <h1
        class="font-barlow font-black text-[clamp(42px,12vw,96px)] leading-[0.9] tracking-tight uppercase"
      >
        <span class="block">HASIRU</span>
        <span class="block text-[#ff3d00]">KAVISHAN</span>
        <span
          class="block"
          style="-webkit-text-stroke:2px #111; color:transparent;"
        >
          BUILDS IT.
        </span>
      </h1>

      <p
        class="text-[13px] text-[#555] leading-relaxed max-w-full md:max-w-sm font-mono"
      >
        Enthusiastic fullstack engineer with 5+ years shipping production apps
        across Node.js, Java, React and cloud platforms. Based in Sri Lanka,
        working globally.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
          <a
            href="mailto:bgh.kavishan@gmail.com"
            class="w-full rounded sm:w-auto bg-[#111] text-[#f2f0eb] px-5 py-3 text-center text-[11px] tracking-widest hover:bg-[#ff3d00] transition-colors"
          >
            EMAIL ME ↗
          </a>

          <div class="border-r border-[#ddd]"></div>

          <div class="flex gap-3">
            <!-- GitHub -->
            <a
              href="https://github.com/YOUR_USERNAME"
              target="_blank"
              class="w-full rounded sm:w-auto border border-[#111] px-4 py-3 flex items-center justify-center hover:bg-[#111] hover:text-[#f2f0eb] transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 .5C5.7.5.7 5.7.7 12c0 5.1 3.3 9.5 7.9 11 .6.1.8-.3.8-.6v-2.2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.6-1.3-1.6-1.1-.8.1-.8.1-.8 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-6 0-1.3.5-2.4 1.3-3.3-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.4 1.3 1-.3 2.1-.4 3.2-.4s2.2.1 3.2.4c2.4-1.6 3.4-1.3 3.4-1.3.7 1.7.2 3 .1 3.3.8.9 1.3 2 1.3 3.3 0 4.7-2.7 5.7-5.3 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.9 7.9-11C23.3 5.7 18.3.5 12 .5z"
                ></path>
              </svg>
            </a>

            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/in/hasiru-kavishan-2715a7a2/"
              target="_blank"
              class="w-full rounded sm:w-auto border border-[#111] px-4 py-3 flex items-center justify-center hover:bg-[#111] hover:text-[#f2f0eb] transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM3.56 20.45h3.56V9H3.56v11.45z"
                ></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Right -->
    <div class="flex flex-col divide-y divide-[#ccc]">
      {
        stats.map((s) => (
          <StatBox label={s.label} value={s.value} small={s.small} />
        ))
      }

      <div class="p-4 md:p-6 flex flex-col gap-1">
        <span class="text-[10px] tracking-[0.15em] text-[#888] uppercase">
          Education
        </span>

        <span class="font-bold text-[15px]"> BSc. Computer Science </span>

        <span class="text-[12px] text-[#888]">
          University of Colombo · 2015–2018
        </span>

        <a
          href="/cv.pdf"
          download
          class="mt-3 rounded inline-flex items-center justify-center w-fit px-4 py-2 text-[11px]
                border border-[#111] hover:bg-[#111] hover:text-[#f2f0eb]
                transition-colors tracking-widest"
        >
          DOWNLOAD CV ↓
        </a>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="work" class="border-b-[3px] border-[#111]">
    <div
      class="px-5 md:px-7 py-3 border-b border-[#ccc] text-[10px] tracking-[0.2em] text-[#888] uppercase"
    >
      Selected Projects
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3">
      {
        works.map((w) => (
          <WorkCard
            num={w.num}
            title={w.title}
            category={w.category}
            accent={w.accent}
            description={w.description}
            link={w.link}
          />
        ))
      }
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="border-b-[3px] border-[#111]">
    <Skills />
  </section>

  <!-- Experience -->
  <section id="experience" class="border-b-[3px] border-[#111]">
    <Experience />
  </section>

  <!-- Footer -->
  <footer
    id="contact"
    class="px-5 md:px-7 py-4 flex flex-col md:flex-row gap-2 md:gap-0 justify-between items-start md:items-center text-[11px] text-[#888]"
  >
    <span>© 2026 Hasiru Kavishan</span>

    <span>+94 712 893 518</span>

    <a
      href="mailto:bgh.kavishan@gmail.com"
      class="hover:text-[#111] transition-colors break-all"
    >
      bgh.kavishan@gmail.com
    </a>
  </footer>
</div>
